#!/usr/bin/env zsh
set -euo pipefail

MAIN_BRANCH="$(git main | sed 's#.*/##')"
if [ -z "$MAIN_BRANCH" ]; then
    echo "Main branch not found"
    exit 1
fi

git switch "$MAIN_BRANCH" && git pull --prune

echo "Deleting squash-merged & normal-merged branches (except $MAIN_BRANCH)"

git for-each-ref --format='%(refname:short)' refs/heads/ |
grep -v "^$MAIN_BRANCH$" |
while read -r branch; do
    # Try normal merge check first (faster)
    if git merge-base --is-ancestor "$branch" "$MAIN_BRANCH" 2>/dev/null; then
        git branch -d "$branch" && echo "Deleted (merged): $branch"
        continue
    fi

    # Squash check
    merge_base=$(git merge-base "$MAIN_BRANCH" "$branch")
    tree_commit=$(git commit-tree "$branch^{tree}" -p "$merge_base" -m "temp" 2>/dev/null)
    if [[ $(git cherry "$MAIN_BRANCH" "$tree_commit") == "-"* ]]; then
        git branch -D "$branch" && echo "Deleted (squash-merged): $branch"
    fi
done
