#!/usr/bin/env zsh
set -euo pipefail

# git-cascade: Checkout and rebase all local branches that have the current
# branch (or a previously cascaded branch) as their upstream. If any rebase
# encounters a conflict, abort the rebase and the cascade.

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  echo "Not a git repository" >&2
  exit 1
fi

CURRENT="$(git rev-parse --abbrev-ref HEAD)"
if [[ -z "$CURRENT" || "$CURRENT" == "HEAD" ]]; then
  echo "Not on a branch" >&2
  exit 1
fi

echo "Cascading rebases for branches tracking '$CURRENT'..."

cascade() {
  local base="$1"
  local -a dependents

  # Find branches whose upstream is exactly $base
  while read -r ref upstream; do
    if [[ -n "$ref" && "$upstream" == "$base" ]]; then
      dependents+=("$ref")
    fi
  done < <(git for-each-ref --format='%(refname:short) %(upstream:short)' refs/heads/)

  local dep
  for dep in "${dependents[@]}"; do
    echo "Rebasing '$dep' (upstream: $base)..."

    if ! git checkout -q "$dep"; then
      echo "Failed to checkout $dep" >&2
      git checkout -q "$CURRENT" 2>/dev/null || true
      return 1
    fi

    if ! git rebase; then
      echo "Rebase conflict for '$dep', aborting..."
      git rebase --abort 2>/dev/null || true
      git checkout -q "$CURRENT" 2>/dev/null || true
      return 1
    fi

    echo "Rebased '$dep' successfully."

    # Recurse to handle any branches tracking this one
    if ! cascade "$dep"; then
      return 1
    fi
  done

  return 0
}

if cascade "$CURRENT"; then
  git checkout -q "$CURRENT"
  echo "Cascade complete."
else
  echo "Cascade aborted."
  exit 1
fi
