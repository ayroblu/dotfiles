#!/usr/bin/env zsh
set -euo pipefail

CURRENT="$(git rev-parse --abbrev-ref HEAD)"
if [ -z "$CURRENT" ]; then
    echo "Not on a branch"
    exit 1
fi

echo "Rebasing branches that depend on $CURRENT..."

# Collect dependent branches with depth (commits since current)
# Use git branch --contains to get only descendants, not all branches
deps=()
while read -r branch; do
    depth=$(git rev-list --count "$CURRENT..$branch")
    deps+=("$depth:$branch")
done < <(git branch --contains "$CURRENT" --format='%(refname:short)' | grep -v "^$CURRENT$")

# Extract just branch names for parent-finding
dep_branches=()
for item in $deps; do
    dep_branches+=(${item#*:})
done

# Sort by depth ascending and rebase each onto its direct parent
for item in ${(on)deps}; do
    branch=${item#*:}

    # Find direct parent: closest ancestor among current + other dependents
    parent="$CURRENT"
    best_count=999999
    for candidate in $CURRENT $dep_branches; do
        if [[ "$candidate" != "$branch" ]] && git merge-base --is-ancestor "$candidate" "$branch" 2>/dev/null; then
            count=$(git rev-list --count "$candidate..$branch")
            if (( count < best_count )); then
                best_count=$count
                parent=$candidate
            fi
        fi
    done

    echo "Rebasing $branch onto $parent..."
    git checkout "$branch" && git rebase "$parent" && git checkout "$CURRENT" || {
        echo "Rebase failed for $branch, aborting..."
        git rebase --abort 2>/dev/null || true
        git checkout "$CURRENT"
    }
done

